{
  "expo": {
    "name": "Adventools",
    "slug": "adventools",
    "version": "1.2.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "adventools",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111621"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adventools",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "NSMicrophoneUsageDescription": "Cette application a besoin d'accéder à votre micro pour enregistrer des notes vocales dans votre journal.",
        "NSCameraUsageDescription": "Cette application a besoin de l'appareil photo pour joindre des photos à vos notes.",
        "NSPhotoLibraryUsageDescription": "Cette application a besoin d'accéder à vos photos pour joindre des images à vos notes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#111621"
      },
      "package": "com.adventools",
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "MODIFY_AUDIO_SETTINGS",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "WAKE_LOCK",
        "INTERNET",
        "POST_NOTIFICATIONS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "REQUEST_INSTALL_PACKAGES"
      ],
      "versionCode": 5,
      "newArchEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "@react-native-community/datetimepicker",
      [
        "expo-av",
        {
          "microphonePermission": "Cette application a besoin d'accéder à votre micro pour enregistrer des notes vocales dans votre journal.",
          "cameraPermission": "Cette application a besoin de l'appareil photo pour joindre des photos à vos notes."
        }
      ],
      "expo-audio",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
